{
  "schemaVersion": 1,
  "shortDesc": "Updating local changes everywhere.",
  "longDesc": "Updating all changes currently in git repository, commiting to local and remote.",
  "actions": [
    {
      "desc": "",
      "step": {
        "prompts": [
          {
            "varName": "commit_msg",
            "prompt": "Commit message?"
          }
        ],
        "command": "git add -A;git commit -m \"$commit_msg\";git push"
      }
    }
  ]
}
